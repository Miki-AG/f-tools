#!/usr/bin/env node

"use strict";

const path = require("path");

const SCRIPT_DIR = __dirname;

function printHelp() {
  process.stdout.write(`Usage:
  f-planner -h
  f-planner help
  f-planner prd
  f-planner <req|plan|doc> <name>

Commands:
  prd   Create the top-level PRD at ./_PLAN/010_PRD.md.
  req   Create a requirement doc in a feature folder under ./_PLAN/<feature-slug>/.
  plan  Create a plan doc in a feature folder under ./_PLAN/<feature-slug>/.
  doc   Create a documentation doc under ./_DOCS/.

Features:
  req and plan slug the feature name into ./_PLAN/<feature-slug>/.
  Example: "Update Workflow" -> ./_PLAN/update-workflow/
  Files created there:
    010_<feature-slug>.REQ.md
    020_<feature-slug>.PLAN.md
`);
}

function runScript(fileName) {
  require(path.join(SCRIPT_DIR, fileName));
}

function main() {
  const cmd = process.argv[2] || "";

  if (!cmd || cmd === "-h" || cmd === "--help" || cmd === "help") {
    printHelp();
    if (!cmd) process.exit(2);
    return;
  }

  process.argv.splice(2, 1);

  if (cmd === "prd") {
    runScript("prd.js");
    return;
  }
  if (cmd === "req") {
    runScript("req.js");
    return;
  }
  if (cmd === "plan") {
    runScript("plan.js");
    return;
  }
  if (cmd === "doc") {
    runScript("doc.js");
    return;
  }

  process.stderr.write(`Unknown command: ${cmd}\n`);
  printHelp();
  process.exit(1);
}

main();
